{
    "name": "sirian/yandex-market-language-parser",
    "description": "Yandex Market Language parser",
    "minimum-stability": "stable",
    "authors": [
        {
            "name": "Vasily Khayrulin",
            "email": "sirianru@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-mbstring": "*",
        "ext-simplexml": "*",
        "ext-xmlreader": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0 || ^13.0",
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "autoload": {
        "psr-4": {
            "Sirian\\YMLParser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sirian\\YMLParser\\Tests\\": "Tests/"
        }
    }
}
